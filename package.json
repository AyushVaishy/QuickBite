{
  "name": "quickbite",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm start --workspace=client\"",
    "build": "npm run build --workspace=client",
    "server": "npm run dev --workspace=server",
    "client": "npm start --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
